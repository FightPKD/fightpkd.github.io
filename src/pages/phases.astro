<script>
  const buttons = document.querySelectorAll('.phase-btn');
  const details = document.querySelectorAll('.phase-detail');
  const prompt = document.getElementById('detail-prompt');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const phase = btn.getAttribute('data-phase');

      // Update button active states
      buttons.forEach(b => b.classList.remove('ring-2', 'ring-offset-2', 'scale-105'));
      btn.classList.add('ring-2', 'ring-offset-2', 'scale-105');

      // Show/hide panels
      details.forEach(d => d.classList.add('hidden'));
      if (prompt) prompt.classList.add('hidden');

      const target = document.getElementById(`detail-${phase}`);
      if (target) {
        target.classList.remove('hidden');
        target.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  });
</script>
