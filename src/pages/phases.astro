---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Clinical Trial Phases" description="Understanding clinical trial phases — how drugs move from early testing to market approval, and what it means for PKD patients.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900">The Journey of a Drug</h1>
      <p class="mt-3 text-lg text-gray-600 max-w-2xl mx-auto">
        From laboratory discovery to your pharmacy — click each step to learn more.
      </p>
    </div>

    <!-- Interactive Timeline -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 md:p-8 mb-10 shadow-sm">
      <div class="grid grid-cols-3 md:grid-cols-6 gap-3 md:gap-2 mb-6">
        <button data-phase="preclinical" class="phase-btn group flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-gray-200 hover:border-gray-400 transition-all cursor-pointer">
          <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-gray-600">Preclinical</span>
          <span class="text-[10px] text-gray-400">3–6 yrs</span>
        </button>

        <button data-phase="phase1" class="phase-btn group flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-teal-200 hover:border-teal-400 transition-all cursor-pointer">
          <div class="w-12 h-12 bg-teal-100 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-teal-700">Phase 1</span>
          <span class="text-[10px] text-gray-400">1–2 yrs</span>
        </button>

        <button data-phase="phase2" class="phase-btn group flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-blue-200 hover:border-blue-400 transition-all cursor-pointer">
          <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-blue-700">Phase 2</span>
          <span class="text-[10px] text-gray-400">2–3 yrs</span>
        </button>

        <button data-phase="phase3" class="phase-btn group flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-purple-200 hover:border-purple-400 transition-all cursor-pointer">
          <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-purple-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-purple-700">Phase 3</span>
          <span class="text-[10px] text-gray-400">3–4 yrs</span>
        </button>

        <button data-phase="review" class="phase-btn group flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-amber-200 hover:border-amber-400 transition-all cursor-pointer">
          <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-amber-700">Review</span>
          <span class="text-[10px] text-gray-400">1–2 yrs</span>
        </button>

        <button data-phase="market" class="phase-btn group flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-emerald-200 hover:border-emerald-400 transition-all cursor-pointer">
          <div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-emerald-700">Approved</span>
          <span class="text-[10px] text-gray-400">Market</span>
        </button>
      </div>

      <!-- Progress bar -->
      <div class="hidden md:flex items-center gap-1 mb-6 px-6">
        <div class="h-1.5 flex-1 rounded-full bg-gray-200"></div>
        <div class="h-1.5 flex-1 rounded-full bg-teal-300"></div>
        <div class="h-1.5 flex-1 rounded-full bg-blue-300"></div>
        <div class="h-1.5 flex-1 rounded-full bg-purple-300"></div>
        <div class="h-1.5 flex-1 rounded-full bg-amber-300"></div>
        <div class="h-1.5 flex-1 rounded-full bg-emerald-300"></div>
      </div>

      <p class="text-center text-sm text-gray-500 mb-4">
        Total average: <strong class="text-gray-900">10–15 years</strong> from discovery to your pharmacy
      </p>

      <!-- Detail panels (hidden by default, shown on click) -->
      <div id="phase-details">
        <!-- Preclinical detail -->
        <div id="detail-preclinical" class="phase-detail hidden">
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
            <div class="flex items-start gap-4 mb-5">
              <div class="w-14 h-14 bg-white rounded-xl border border-gray-200 flex items-center justify-center shrink-0">
                <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900">Preclinical Research</h3>
                <p class="text-gray-500 text-sm">Before any human ever takes the drug</p>
              </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
              <div class="bg-white rounded-lg p-3 border border-gray-100 text-center">
                <svg class="w-5 h-5 text-gray-400 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-xs text-gray-500">Duration</p>
                <p class="font-bold text-gray-900">3–6 years</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-gray-100 text-center">
                <svg class="w-5 h-5 text-gray-400 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
                <p class="text-xs text-gray-500">Subjects</p>
                <p class="font-bold text-gray-900">Cells & Animals</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-gray-100 text-center">
                <svg class="w-5 h-5 text-gray-400 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                <p class="text-xs text-gray-500">Advance rate</p>
                <p class="font-bold text-gray-900">~10%</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-gray-100 text-center">
                <svg class="w-5 h-5 text-gray-400 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                <p class="text-xs text-gray-500">Goal</p>
                <p class="font-bold text-gray-900">Show promise</p>
              </div>
            </div>

            <div class="space-y-3 text-sm text-gray-600">
              <p>Scientists test thousands of compounds in lab dishes and animal models. For PKD, researchers use mice or rats with cystic kidneys to see if a drug can slow or stop cyst growth.</p>
              <p>Only about <strong>1 in 10</strong> compounds that enter preclinical testing will ever be tested in humans. The vast majority are eliminated because they're toxic, don't work well enough, or can't be manufactured at scale.</p>
            </div>
          </div>
        </div>

        <!-- Phase 1 detail -->
        <div id="detail-phase1" class="phase-detail hidden">
          <div class="bg-teal-50 rounded-xl p-6 border border-teal-200">
            <div class="flex items-start gap-4 mb-5">
              <div class="w-14 h-14 bg-white rounded-xl border border-teal-200 flex items-center justify-center shrink-0">
                <svg class="w-8 h-8 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900">Phase 1 — Is It Safe?</h3>
                <p class="text-gray-500 text-sm">First time the drug is given to humans</p>
              </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
              <div class="bg-white rounded-lg p-3 border border-teal-100 text-center">
                <svg class="w-5 h-5 text-teal-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-xs text-gray-500">Duration</p>
                <p class="font-bold text-gray-900">1–2 years</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-teal-100 text-center">
                <svg class="w-5 h-5 text-teal-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                <p class="text-xs text-gray-500">Participants</p>
                <p class="font-bold text-gray-900">20–100</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-teal-100 text-center">
                <svg class="w-5 h-5 text-teal-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                <p class="text-xs text-gray-500">Success rate</p>
                <p class="font-bold text-gray-900">63%</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-teal-100 text-center">
                <svg class="w-5 h-5 text-teal-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                <p class="text-xs text-gray-500">Key question</p>
                <p class="font-bold text-gray-900">Is it safe?</p>
              </div>
            </div>

            <div class="space-y-3 text-sm text-gray-600">
              <p>A small group of people (often healthy volunteers) receives the drug for the first time. Doctors start with tiny doses and slowly increase, watching closely for side effects.</p>
              <p>The goal isn't to cure anyone yet — it's to answer: <em>Can humans tolerate this drug? How does the body absorb and process it? What dose range is safe?</em></p>
            </div>

            <div class="mt-4 bg-white border border-teal-200 rounded-lg p-4">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <span class="text-sm font-semibold text-teal-800">PKD Drugs Currently in Phase 1</span>
              </div>
              <p class="text-sm text-gray-600"><strong>PYC-003</strong> — antisense therapy targeting PKD1 mutations (Australia)<br/><strong>AZD1613</strong> — AstraZeneca's novel PAPPA-1 inhibitor (UK/US/China)</p>
            </div>
          </div>
        </div>

        <!-- Phase 2 detail -->
        <div id="detail-phase2" class="phase-detail hidden">
          <div class="bg-blue-50 rounded-xl p-6 border border-blue-200">
            <div class="flex items-start gap-4 mb-5">
              <div class="w-14 h-14 bg-white rounded-xl border border-blue-200 flex items-center justify-center shrink-0">
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900">Phase 2 — Does It Actually Work?</h3>
                <p class="text-gray-500 text-sm">First real test of effectiveness in patients</p>
              </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
              <div class="bg-white rounded-lg p-3 border border-blue-100 text-center">
                <svg class="w-5 h-5 text-blue-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-xs text-gray-500">Duration</p>
                <p class="font-bold text-gray-900">2–3 years</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-blue-100 text-center">
                <svg class="w-5 h-5 text-blue-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <p class="text-xs text-gray-500">Participants</p>
                <p class="font-bold text-gray-900">100–300</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-blue-100 text-center">
                <svg class="w-5 h-5 text-blue-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                <p class="text-xs text-gray-500">Success rate</p>
                <p class="font-bold text-gray-900">31%</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-blue-100 text-center">
                <svg class="w-5 h-5 text-blue-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                <p class="text-xs text-gray-500">Key question</p>
                <p class="font-bold text-gray-900">Does it help?</p>
              </div>
            </div>

            <div class="space-y-3 text-sm text-gray-600">
              <p>Now the drug is given to people who actually have the disease. For PKD trials, researchers use MRI scans to measure kidney volume changes and blood tests to track kidney function (eGFR).</p>
              <p><strong>This is where most drugs fail.</strong> About 70% of drugs that enter Phase 2 never make it to Phase 3 — they may be safe but simply don't work well enough against the disease.</p>
            </div>

            <div class="mt-4 bg-white border border-blue-200 rounded-lg p-4">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <span class="text-sm font-semibold text-blue-800">PKD Drugs Currently in Phase 2</span>
              </div>
              <p class="text-sm text-gray-600"><strong>ABBV-CLS-628</strong> — 240 patients, kidney volume endpoint<br/><strong>VX-407</strong> — Vertex's precision approach (like their CF drugs)<br/><strong>Tirzepatide</strong> — weight loss drug being tested in overweight PKD patients<br/><strong>Bempedoic Acid</strong> — AMPK activator targeting cyst metabolism</p>
            </div>
          </div>
        </div>

        <!-- Phase 3 detail -->
        <div id="detail-phase3" class="phase-detail hidden">
          <div class="bg-purple-50 rounded-xl p-6 border border-purple-200">
            <div class="flex items-start gap-4 mb-5">
              <div class="w-14 h-14 bg-white rounded-xl border border-purple-200 flex items-center justify-center shrink-0">
                <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900">Phase 3 — Proving It at Scale</h3>
                <p class="text-gray-500 text-sm">The make-or-break trial for FDA approval</p>
              </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
              <div class="bg-white rounded-lg p-3 border border-purple-100 text-center">
                <svg class="w-5 h-5 text-purple-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-xs text-gray-500">Duration</p>
                <p class="font-bold text-gray-900">3–4 years</p>
              </div>
              <div class="bg-white rounded-lg p-3 border border-purple-100 text-center">
                <svg class="w-5 h-5 text-purple-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
