---
import BaseLayout from '../layouts/BaseLayout.astro';
import drugs from '../data/drugs.json';

const recruitingDrugs = drugs.filter(d => d.status === 'recruiting');
const totalRecruiting = recruitingDrugs.length;
---

<BaseLayout title="Currently Recruiting Trials" description="PKD clinical trials currently recruiting patients. Find enrollment links and eligibility information." keywords="PKD clinical trials recruiting, ADPKD trial enrollment, polycystic kidney disease study volunteer, PKD drug trial sign up">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Currently Recruiting</h1>
      <p class="text-lg text-gray-600">
        {totalRecruiting} drug trials actively seeking PKD patients. Links go directly to ClinicalTrials.gov enrollment pages.
      </p>
    </header>

    <!-- How to enroll -->
    <div class="bg-primary-50 border border-primary-200 rounded-xl p-5 mb-10">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <p class="text-sm text-primary-900 font-medium mb-1">How to enroll in a clinical trial</p>
          <p class="text-sm text-primary-800">Click the "View on ClinicalTrials.gov" link for any trial below to see eligibility criteria, locations, and contact information. Always discuss participation with your nephrologist first.</p>
        </div>
      </div>
    </div>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-gray-900 mb-2 flex items-center gap-2">
        <span class="w-3 h-3 bg-emerald-500 rounded-full"></span>
        Drug Trials Enrolling Patients ({recruitingDrugs.length})
      </h2>
      <p class="text-sm text-gray-500 mb-5">Click "View on ClinicalTrials.gov" for eligibility criteria, locations, and contact information</p>
      <div class="space-y-4">
        {recruitingDrugs.map((drug) => (
          <div class="bg-white border border-gray-200 rounded-xl p-5 hover:border-emerald-200 transition-colors">
            <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <a href={`/drugs/${drug.id}`} class="font-semibold text-gray-900 hover:text-primary-600 transition-colors">{drug.name}</a>
                  <span class="px-2 py-0.5 bg-blue-100 text-blue-800 rounded-full text-xs font-medium">Phase {drug.phase}</span>
                </div>
                <p class="text-sm text-gray-600 mb-2">{drug.mechanism.split('—')[0].trim()}</p>
                <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500">
                  <span>{drug.company}</span>
                  <span>{drug.trialName}</span>
                  {drug.participants > 0 && <span>{drug.participants} participants</span>}
                  {drug.estimatedCompletion && <span>Est. completion: {drug.estimatedCompletion}</span>}
                </div>
              </div>
              <div class="flex flex-col gap-2 shrink-0">
                {drug.nctId && (
                  <a href={`https://clinicaltrials.gov/study/${drug.nctId}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-2 text-xs font-medium text-white bg-emerald-600 hover:bg-emerald-700 rounded-lg transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    View on ClinicalTrials.gov
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="mt-8 bg-amber-50 border border-amber-200 rounded-xl p-4">
      <p class="text-xs text-amber-800">
        <strong>Disclaimer:</strong> Enrollment links direct to ClinicalTrials.gov, where you can find full eligibility criteria and site locations. Meeting eligibility criteria does not guarantee enrollment. Always consult your nephrologist before participating in a clinical trial.
      </p>
    </div>
  </div>
</BaseLayout>
