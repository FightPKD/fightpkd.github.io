---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import news from '../../data/news.json';
import drugs from '../../data/drugs.json';

export function getStaticPaths() {
  return news.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;

const categoryLabels: Record<string, string> = {
  'clinical-data': 'Clinical Data',
  'regulatory': 'Regulatory',
  'trial-update': 'Trial Update',
  'conference': 'Conference',
  'acquisition': 'Acquisition',
  'approval': 'Approval',
};

const categoryColors: Record<string, string> = {
  'clinical-data': 'bg-blue-100 text-blue-800',
  'regulatory': 'bg-purple-100 text-purple-800',
  'trial-update': 'bg-teal-100 text-teal-800',
  'conference': 'bg-amber-100 text-amber-800',
  'acquisition': 'bg-indigo-100 text-indigo-800',
  'approval': 'bg-emerald-100 text-emerald-800',
};

const formattedDate = new Date(article.date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const relatedDrugDetails = article.relatedDrugs.map((drugId: string) => {
  const drug = drugs.find((d: any) => d.id === drugId);
  return drug ? { id: drug.id, name: drug.name, phase: drug.phase } : null;
}).filter(Boolean) as { id: string; name: string; phase: number }[];
---

<BaseLayout title={article.title} description={article.summary}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="mb-6 text-sm">
      <ol class="flex items-center gap-2 text-gray-500">
        <li><a href="/news" class="hover:text-primary-600 transition-colors">News</a></li>
        <li><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-gray-900 font-medium truncate max-w-[300px]">{article.title}</li>
      </ol>
    </nav>

    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-3">
        <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${categoryColors[article.category] || 'bg-gray-100 text-gray-800'}`}>
          {categoryLabels[article.category] || article.category}
        </span>
        <time class="text-sm text-gray-500" datetime={article.date}>{formattedDate}</time>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900">{article.title}</h1>
    </header>

    <article class="space-y-8">
      <section>
        <div class="bg-primary-50 border border-primary-200 rounded-xl p-5">
          <p class="text-sm text-primary-900 leading-relaxed">{article.summary}</p>
        </div>
      </section>

      <section class="space-y-4">
        {article.body.map((paragraph: string) => (
          <p class="text-gray-700 leading-relaxed">{paragraph}</p>
        ))}
      </section>

      {relatedDrugDetails.length > 0 && (
        <section>
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Related Drugs</h2>
          <div class="flex flex-wrap gap-3">
            {relatedDrugDetails.map((drug) => (
              <a
                href={`/drugs/${drug.id}`}
                class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-lg hover:border-primary-300 hover:shadow-sm transition-all"
              >
                <span class="text-sm font-medium text-gray-900">{drug.name}</span>
                <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full">Phase {drug.phase}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {article.sourceUrl && (
        <section>
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Source</h2>
          <a
            href={article.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors"
          >
            {article.sourceName}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </section>
      )}

      {article.tags && (
        <section>
          <div class="flex flex-wrap gap-2">
            {article.tags.map((tag: string) => (
              <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium">
                {tag}
              </span>
            ))}
          </div>
        </section>
      )}
    </article>

    <div class="mt-12 pt-8 border-t border-gray-200">
      <a href="/news" class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to News
      </a>
    </div>

    <div class="mt-8">
      <NewsletterSignup compact />
    </div>

    <div class="mt-8 bg-amber-50 border border-amber-200 rounded-xl p-4">
      <p class="text-xs text-amber-800">
        <strong>Disclaimer:</strong> This information is for educational purposes only and is not medical advice. News articles are based on publicly available data from ClinicalTrials.gov, company press releases, and published research. Consult your nephrologist before making treatment decisions.
      </p>
    </div>
  </div>
</BaseLayout>
