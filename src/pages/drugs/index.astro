---
import BaseLayout from '../../layouts/BaseLayout.astro';
import drugs from '../../data/drugs.json';
import articles from '../../data/drug-articles.json';

const articlesData = articles as Record<string, any>;

const drugsByPhase = [4, 3, 2, 1].map(phase => ({
  phase,
  drugs: drugs.filter(d => d.phase === phase).sort((a, b) => {
    const aHasArticle = articlesData[a.id] ? 1 : 0;
    const bHasArticle = articlesData[b.id] ? 1 : 0;
    return bHasArticle - aHasArticle;
  }),
})).filter(g => g.drugs.length > 0);

const phaseConfig: Record<number, { label: string; color: string; border: string; bg: string }> = {
  4: { label: 'Approved', color: 'text-emerald-700', border: 'border-emerald-200', bg: 'bg-emerald-50' },
  3: { label: 'Phase 3', color: 'text-indigo-700', border: 'border-indigo-200', bg: 'bg-indigo-50' },
  2: { label: 'Phase 2', color: 'text-blue-700', border: 'border-blue-200', bg: 'bg-blue-50' },
  1: { label: 'Phase 1', color: 'text-teal-700', border: 'border-teal-200', bg: 'bg-teal-50' },
};

const statusLabels: Record<string, string> = {
  recruiting: 'Recruiting',
  not_yet_recruiting: 'Not Yet Recruiting',
  active_not_recruiting: 'Active',
  completed: 'Completed',
  enrolling_by_invitation: 'By Invitation',
  approved: 'FDA Approved',
};

const statusColors: Record<string, string> = {
  recruiting: 'text-emerald-700 bg-emerald-50',
  not_yet_recruiting: 'text-amber-700 bg-amber-50',
  active_not_recruiting: 'text-sky-700 bg-sky-50',
  completed: 'text-gray-600 bg-gray-50',
  enrolling_by_invitation: 'text-purple-700 bg-purple-50',
  approved: 'text-emerald-700 bg-emerald-50',
};
---

<BaseLayout title="Drug Research Articles" description="In-depth articles on every drug in the PKD clinical trial pipeline — mechanisms, trial details, and what they mean for patients.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Drug Research Articles</h1>
      <p class="text-lg text-gray-600 max-w-3xl">
        In-depth analysis of every drug being tested for Polycystic Kidney Disease — how they work, trial progress, and what they could mean for patients.
      </p>
    </div>

    {drugsByPhase.map(({ phase, drugs: phaseDrugs }) => (
      <section class="mb-12">
        <div class={`flex items-center gap-3 mb-5 pb-3 border-b ${phaseConfig[phase].border}`}>
          <span class={`px-3 py-1 rounded-full text-sm font-semibold ${phaseConfig[phase].bg} ${phaseConfig[phase].color}`}>
            {phaseConfig[phase].label}
          </span>
          <span class="text-sm text-gray-500">{phaseDrugs.length} {phaseDrugs.length === 1 ? 'drug' : 'drugs'}</span>
        </div>

        <div class="grid gap-4">
          {phaseDrugs.map((drug) => {
            const article = articlesData[drug.id];
            return (
              <a href={`/drugs/${drug.id}`} class="group block bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md hover:border-primary-200 transition-all">
                <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-5">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1.5">
                      <h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition-colors truncate">{drug.name}</h3>
                      <span class={`shrink-0 px-2 py-0.5 rounded-full text-[10px] font-medium ${statusColors[drug.status] || 'text-gray-600 bg-gray-50'}`}>
                        {statusLabels[drug.status] || drug.status}
                      </span>
                    </div>
                    {article ? (
                      <p class="text-sm text-gray-600 line-clamp-2">{article.headline}</p>
                    ) : (
                      <p class="text-sm text-gray-400 italic">Article coming soon</p>
                    )}
                    <p class="text-xs text-gray-500 mt-2">{drug.company} — {drug.mechanism.split('—')[0].trim()}</p>
                  </div>
                  <svg class="w-5 h-5 text-gray-300 group-hover:text-primary-500 shrink-0 transition-colors hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <div class="text-center mt-8">
      <a href="/pipeline" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors text-sm">
        View Pipeline Dashboard
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</BaseLayout>
