---
interface Props {
  name: string;
  company: string;
  companyLocation: string;
  phase: number;
  status: string;
  trialName: string;
  startDate: string;
  mechanism: string;
  participants: number;
  nctId: string;
  notes: string;
}

const { name, company, companyLocation, phase, status, trialName, startDate, mechanism, participants, nctId, notes } = Astro.props;

const statusConfig: Record<string, { label: string; class: string }> = {
  recruiting: { label: 'Recruiting', class: 'bg-emerald-100 text-emerald-800' },
  not_yet_recruiting: { label: 'Not Yet Recruiting', class: 'bg-amber-100 text-amber-800' },
  active_not_recruiting: { label: 'Active', class: 'bg-blue-100 text-blue-800' },
  completed: { label: 'Completed', class: 'bg-gray-100 text-gray-700' },
  enrolling_by_invitation: { label: 'By Invitation', class: 'bg-purple-100 text-purple-800' },
};

const phaseConfig: Record<number, { label: string; class: string }> = {
  1: { label: 'Phase 1', class: 'bg-cyan-100 text-cyan-800 border-cyan-200' },
  2: { label: 'Phase 2', class: 'bg-blue-100 text-blue-800 border-blue-200' },
  3: { label: 'Phase 3', class: 'bg-indigo-100 text-indigo-800 border-indigo-200' },
};

const statusInfo = statusConfig[status] || { label: status, class: 'bg-gray-100 text-gray-700' };
const phaseInfo = phaseConfig[phase] || { label: `Phase ${phase}`, class: 'bg-gray-100 text-gray-700 border-gray-200' };
---

<div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-primary-200 transition-all duration-200">
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-semibold text-lg text-gray-900">{name}</h3>
    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${phaseInfo.class}`}>
      {phaseInfo.label}
    </span>
  </div>

  <div class="flex items-center gap-2 mb-3">
    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusInfo.class}`}>
      {status === 'recruiting' && <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mr-1 animate-pulse"></span>}
      {statusInfo.label}
    </span>
    {trialName && <span class="text-xs text-gray-500">{trialName}</span>}
  </div>

  <div class="space-y-2 text-sm text-gray-600 mb-4">
    <div class="flex items-start gap-2">
      <svg class="w-4 h-4 mt-0.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
      </svg>
      <span>{company} — {companyLocation}</span>
    </div>
    <div class="flex items-start gap-2">
      <svg class="w-4 h-4 mt-0.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
      </svg>
      <span>{mechanism}</span>
    </div>
    {startDate && (
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span>Started: {startDate}</span>
      </div>
    )}
    {participants > 0 && (
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>{participants} participants</span>
      </div>
    )}
  </div>

  {notes && <p class="text-xs text-gray-500 border-t border-gray-100 pt-3">{notes}</p>}

  {nctId && (
    <a
      href={`https://clinicaltrials.gov/study/${nctId}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 mt-3 text-xs text-primary-600 hover:text-primary-700 font-medium"
    >
      View on ClinicalTrials.gov
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  )}
</div>
