---
interface Props {
  name: string;
  category: string;
  status: string;
  studyName: string;
  institution: string;
  resultsSummary: string;
  link: string;
  publicationDate: string;
  researchers: string;
}

const { name, category, status, studyName, institution, resultsSummary, link, publicationDate, researchers } = Astro.props;

const statusConfig: Record<string, { label: string; class: string; icon: string }> = {
  completed: { label: 'Completed', class: 'bg-emerald-100 text-emerald-800', icon: '✓' },
  in_progress: { label: 'In Progress', class: 'bg-blue-100 text-blue-800', icon: '◆' },
  observational: { label: 'Observational', class: 'bg-amber-100 text-amber-800', icon: '○' },
};

const categoryConfig: Record<string, { label: string; class: string }> = {
  dietary: { label: 'Dietary', class: 'text-green-700 bg-green-50 border-green-200' },
  supplement: { label: 'Supplement', class: 'text-purple-700 bg-purple-50 border-purple-200' },
  lifestyle: { label: 'Lifestyle', class: 'text-orange-700 bg-orange-50 border-orange-200' },
  repurposed_drug: { label: 'Repurposed Drug', class: 'text-blue-700 bg-blue-50 border-blue-200' },
};

const statusInfo = statusConfig[status] || { label: status, class: 'bg-gray-100 text-gray-700', icon: '•' };
const categoryInfo = categoryConfig[category] || { label: category, class: 'text-gray-700 bg-gray-50 border-gray-200' };
---

<div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-primary-200 transition-all duration-200">
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-semibold text-lg text-gray-900">{name}</h3>
    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border ${categoryInfo.class}`}>
      {categoryInfo.label}
    </span>
  </div>

  <div class="flex items-center gap-2 mb-4">
    <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusInfo.class}`}>
      <span class="mr-1">{statusInfo.icon}</span>
      {statusInfo.label}
    </span>
    <span class="text-xs text-gray-500">{studyName}</span>
  </div>

  <p class="text-sm text-gray-600 mb-4">{resultsSummary}</p>

  <div class="flex items-center justify-between text-xs text-gray-500 border-t border-gray-100 pt-3">
    <span>{institution}</span>
    {publicationDate && <span>{publicationDate}</span>}
  </div>

  {researchers && (
    <p class="text-xs text-gray-400 mt-2">Researchers: {researchers}</p>
  )}

  {link && (
    <a
      href={link}
      class="inline-flex items-center gap-1 mt-3 text-xs text-primary-600 hover:text-primary-700 font-medium"
    >
      Read more
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  )}
</div>
